// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Venue {
  SMACK
  NEON
}

enum TicketStatus {
  AVAILABLE
  SOLD
  CANCELLED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tickets       Ticket[] @relation("SellerTickets")
  ticketsBought Ticket[] @relation("BuyerTickets")
}

model Ticket {
  id          String       @id @default(cuid())
  venue       Venue
  eventName   String
  eventDate   DateTime
  ticketType  String?
  resalePrice Float
  imageUrl    String
  description String?
  status      TicketStatus @default(AVAILABLE)
  sellerId    String
  seller      User         @relation("SellerTickets", fields: [sellerId], references: [id], onDelete: Cascade)
  buyerId     String?
  buyer       User?        @relation("BuyerTickets", fields: [buyerId], references: [id], onDelete: SetNull)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}
