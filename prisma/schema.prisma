// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Venue {
  SMACK
  NEON
}

enum TicketStatus {
  AVAILABLE
  SOLD
  CANCELLED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tickets   Ticket[]
}

model Ticket {
  id            String       @id @default(cuid())
  venue         Venue
  eventName     String
  eventDate     DateTime
  ticketType    String
  originalPrice Float
  resalePrice   Float
  imageUrl      String
  description   String?
  status        TicketStatus @default(AVAILABLE)
  sellerId      String
  seller        User         @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}
